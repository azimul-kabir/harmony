APP_NAME=Harmony
MUSICBRAINZ_BASE_URL=https://musicbrainz.org/ws/2
MUSICBRAINZ_USER_AGENT=Harmony/1.6.0 (https://github.com/azimul-kabir/harmony)
MUSICBRAINZ_TIMEOUT_SECONDS=10
MUSICBRAINZ_MAX_RETRIES=3
MUSICBRAINZ_BACKOFF_SECONDS=0.5
MUSICBRAINZ_REQUESTS_PER_SECOND=1
MUSICBRAINZ_CACHE_TTL_SECONDS=86400
MUSICBRAINZ_MAX_CONCURRENT_REQUESTS=2
COVER_ART_ARCHIVE_BASE_URL=https://coverartarchive.org
COVER_ART_ARCHIVE_TIMEOUT_SECONDS=20
COVER_ART_ARCHIVE_MAX_BYTES=15728640
APP_VERSION=1.6.0

HOST=0.0.0.0
PORT=8080

DATABASE_URL=sqlite:////database/harmony.db

MUSIC_PATH=/path/to/music
ARTWORK_CACHE_PATH=/path/to/database/artwork

DOWNLOAD_PATH=/path/to/downloads
STAGING_PATH=/path/to/staging
FAILED_PATH=/path/to/failed

LOG_LEVEL=INFO

SPOTDL_PATH=spotdl
YT_DLP_PATH=yt-dlp
YOUTUBE_MUSIC_ENABLED=true
DEFAULT_DOWNLOAD_SOURCE=spotify
YOUTUBE_MUSIC_TIMEOUT_SECONDS=300
YOUTUBE_MUSIC_AUDIO_QUALITY=0
YOUTUBE_MUSIC_MAX_PLAYLIST_ITEMS=500
YOUTUBE_MUSIC_MAX_SEARCH_RESULTS=25
YOUTUBE_MUSIC_MAX_QUEUE_ITEMS=500

USE_OFFICIAL_SPOTIFY_API=false
SPOTIFY_METADATA_PROVIDER=spotify
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_GENRE_ENRICHMENT_ENABLED=false
SPOTIFY_GENRE_MAX_VALUES=3
SPOTIFY_GENRE_INCLUDE_FEATURED_FALLBACK=true
SPOTIFY_GENRE_MERGE_FEATURED=false
SPOTIFY_GENRE_REPLACE_EXISTING=false

AUDIO_PROVIDERS=youtube-music,youtube

MAX_PARALLEL_DOWNLOADS=4

LIBRARY_WATCHER_ENABLED=true
LIBRARY_WATCHER_DEBOUNCE_SECONDS=0.75

# Navidrome must be reachable from inside the Harmony container.
NAVIDROME_URL=http://navidrome:4533
NAVIDROME_USERNAME=
NAVIDROME_PASSWORD=
NAVIDROME_TIMEOUT_SECONDS=5
# After a playlist task finishes, scan new audio, rewrite its M3U, then run
# one final incremental playlist-import scan.
NAVIDROME_PLAYLIST_REIMPORT_ENABLED=true
NAVIDROME_PLAYLIST_REIMPORT_DEBOUNCE_SECONDS=10
NAVIDROME_PLAYLIST_REIMPORT_POLL_SECONDS=2
NAVIDROME_PLAYLIST_REIMPORT_SCAN_TIMEOUT_SECONDS=900
